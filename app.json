{
  "expo": {
    "name": "Flyx",
    "slug": "flyx",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a120a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "updates": {
      "url": "https://u.expo.dev/a8c20525-867a-4411-a6de-427d19db6fab"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.flyx.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./adaptive-icon.png",
        "backgroundColor": "#0a120a"
      },
      "package": "com.flyx.app",
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            { "scheme": "https", "host": "*.strem.io" },
            { "scheme": "stremio" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./favicon.png"
    },
    "plugins": [
      ["expo-screen-orientation", { "initialOrientation": "PORTRAIT" }],
      ["expo-av", { "microphonePermission": "Allow Flyx to access your microphone." }],
      [
        "@sentry/react-native/expo",
        {
          "organization": "alex-qop",
          "project": "REPLACE_WITH_YOUR_SENTRY_PROJECT_NAME"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "a8c20525-867a-4411-a6de-427d19db6fab"
      }
    } 
  }
}
